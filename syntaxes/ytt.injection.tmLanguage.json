{
  "scopeName": "ytt.injection",
  "injectionSelector": "L:source.yaml",
  "patterns": [
    {
      "include": "#ytt-text-template"
    },
    {
      "include": "#ytt-inline-expression"
    },
    {
      "include": "#ytt-annotations"
    },
    {
      "include": "#ytt-definitions"
    },
    {
      "include": "#ytt-directives"
    },
    {
      "include": "#ytt-statements"
    },
    {
      "include": "#ytt-comments"
    }
  ],
  "repository": {
    "ytt-comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign-bang.ytt",
          "match": "^\\s*(#!).*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.ytt"
            }
          }
        },
        {
          "name": "comment.line.number-sign-bang.ytt",
          "match": "\\s+(#!).*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.ytt"
            }
          }
        }
      ]
    },
    "ytt-annotations": {
      "patterns": [
        {
          "name": "meta.annotation.ytt",
          "begin": "^\\s*(#@)(overlay|yaml|data|schema)(/[\\w-]+)+\\b",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.directive.ytt"
            },
            "2": {
              "name": "support.type.annotation-root.ytt"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#ytt-expressions"
            }
          ]
        }
      ]
    },
    "ytt-definitions": {
      "patterns": [
        {
          "name": "meta.function.ytt",
          "begin": "^\\s*(#@)\\s*(def)\\s*([A-Za-z_][\\w]*)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.directive.ytt"
            },
            "2": {
              "name": "keyword.control.def.ytt"
            },
            "3": {
              "name": "entity.name.function.ytt"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#ytt-expressions"
            }
          ]
        }
      ]
    },
    "ytt-directives": {
      "patterns": [
        {
          "name": "meta.directive.ytt",
          "begin": "^\\s*(#@)\\s*(if/end|for/end|if|elif|else|for|end|load|return|yaml)\\b",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.directive.ytt"
            },
            "2": {
              "name": "keyword.control.ytt"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#ytt-expressions"
            }
          ]
        }
      ]
    },
    "ytt-statements": {
      "patterns": [
        {
          "name": "meta.statement.ytt",
          "begin": "^\\s*(#@)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.directive.ytt"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#ytt-expressions"
            }
          ]
        }
      ]
    },
    "ytt-inline-expression": {
      "patterns": [
        {
          "name": "meta.inline-expression.ytt",
          "begin": "(:\\s*)(#@)",
          "beginCaptures": {
            "2": {
              "name": "punctuation.definition.directive.ytt"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#ytt-expressions"
            }
          ]
        },
        {
          "name": "meta.inline-expression.ytt",
          "begin": "(^\\s*-\\s*)(#@)",
          "beginCaptures": {
            "2": {
              "name": "punctuation.definition.directive.ytt"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#ytt-expressions"
            }
          ]
        }
      ]
    },
    "ytt-text-template": {
      "patterns": [
        {
          "name": "meta.text-template.ytt",
          "begin": "\\(@[-=]?",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template.begin.ytt"
            }
          },
          "end": "[-=]?@\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template.end.ytt"
            }
          },
          "patterns": [
            {
              "include": "#ytt-expressions"
            }
          ]
        }
      ]
    },
    "ytt-expressions": {
      "patterns": [
        {
          "name": "string.quoted.triple.double.ytt",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.triple.single.ytt",
          "begin": "'''",
          "end": "'''"
        },
        {
          "name": "string.quoted.double.ytt",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ytt",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.ytt",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.ytt",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "support.function.ytt",
          "match": "\\b[A-Za-z_][\\w.]*\\s*(?=\\()"
        },
        {
          "name": "variable.language.ytt",
          "match": "\\b(?:True|False|None)\\b"
        },
        {
          "name": "support.variable.module.ytt",
          "match": "\\b(?:assert|data|overlay|struct|template|yaml)\\b"
        },
        {
          "name": "keyword.operator.logical.ytt",
          "match": "\\b(?:and|or|not|in)\\b"
        },
        {
          "name": "keyword.operator.comparison.ytt",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.ytt",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.ytt",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "constant.numeric.ytt",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        },
        {
          "name": "variable.other.ytt",
          "match": "\\b[A-Za-z_][\\w.]*\\b"
        },
        {
          "name": "punctuation.separator.ytt",
          "match": "[()\\[\\]{},.:]"
        }
      ]
    }
  }
}
