{
    "comments": {
        "lineComment": "#!"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*#@\\s*(if|elif|else|for|def)\\b",
            "end": "^\\s*#@\\s*(elif|else|end)\\b"
        }
    },
    "indentationRules": {
        "increaseIndentPattern": "^\\s*#@\\s*(if|for|def)\\b|^(?!\\s*#)(?:\\s*-\\s+)?[^\\s#][^#]*:\\s*$",
        "decreaseIndentPattern": "^\\s*#@\\s*(elif|else|end)\\b"
    }
}
